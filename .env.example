# ============================================================
# DT's Vacation & Travel Ltd. — Environment Variables Template
# ============================================================
# Copy this file, rename to .env.local for local development.
# Add these to Vercel: Project Settings → Environment Variables
#
# ⚠️  NEVER commit .env.local to git (it's in .gitignore)
# ============================================================

# --- Supabase ---
# Found at: supabase.com → Your Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# --- Email Sending (Resend.com) ---
# Status: PENDING — Owner signing up for Resend account
# Found at: resend.com → API Keys
# Receiver (Agency): dtvacationandtravel@gmail.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# --- Optional: Sender Email Address ---
# Must be a verified domain/address on Resend
EMAIL_FROM=noreply@yourdomain.com
EMAIL_TO=dtvacationandtravel@gmail.com
